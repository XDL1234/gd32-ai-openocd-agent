# GD32 Agent 配置文件
# 安装后请根据实际环境修改
# 注意：路径统一使用正斜杠 (/)，例如 D:/openocd/bin/openocd.exe

# OpenOCD 路径（留空则自动检测）
OPENOCD_PATH=""

# GDB 路径（留空则使用 arm-none-eabi-gdb）
GDB_PATH=""

# 串口配置（detect-serial.sh 可自动检测）
SERIAL_PORT="COM3"
SERIAL_BAUDRATE="115200"

# OpenOCD 配置文件路径
OPENOCD_CFG=".gd32-agent/openocd.cfg"
